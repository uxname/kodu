{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "cleaner": {
      "default": {
        "whitelist": ["//!"],
        "keepJSDoc": true,
        "useGitignore": true,
        "ignore": []
      },
      "type": "object",
      "properties": {
        "whitelist": {
          "default": ["//!"],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "keepJSDoc": {
          "default": true,
          "type": "boolean"
        },
        "useGitignore": {
          "default": true,
          "type": "boolean"
        },
        "ignore": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["whitelist", "keepJSDoc", "useGitignore", "ignore"],
      "additionalProperties": false
    },
    "packer": {
      "default": {
        "ignore": [
          "package-lock.json",
          "yarn.lock",
          "pnpm-lock.yaml",
          ".git",
          ".kodu",
          "node_modules",
          "dist",
          "coverage"
        ],
        "useGitignore": true,
        "contentBasedBinaryDetection": false
      },
      "type": "object",
      "properties": {
        "ignore": {
          "default": [
            "package-lock.json",
            "yarn.lock",
            "pnpm-lock.yaml",
            ".git",
            ".kodu",
            "node_modules",
            "dist",
            "coverage"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "useGitignore": {
          "default": true,
          "type": "boolean"
        },
        "contentBasedBinaryDetection": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": ["ignore", "useGitignore", "contentBasedBinaryDetection"],
      "additionalProperties": false
    },
    "prompts": {
      "type": "object",
      "properties": {
        "pack": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["cleaner", "packer"],
  "additionalProperties": false
}
