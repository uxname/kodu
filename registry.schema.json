{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "projects": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string"
          },
          "stands": {
            "default": ["local", "dev", "stage", "prod"],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["path", "stands"],
        "additionalProperties": false
      }
    }
  },
  "required": ["projects"],
  "additionalProperties": false
}
